<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ guide_first }} … {{ guide_last }} — UNSPSC A–Z</title>
<style>
  :root { color-scheme: light dark; }
  * { box-sizing: border-box; }
  body { margin: 0; padding: 2rem 1rem; font: 16px/1.5 system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; background: #f4f5f7; color: #1c2024; }
  .card { max-width: 60rem; margin: 0 auto; padding: 1.5rem 2rem; background: #fff; border: 1px solid #d8dbe0; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
  .breadcrumb { font-size: .85rem; margin-bottom: 1rem; color: #6b7280; }
  .breadcrumb a { color: #2563eb; text-decoration: none; }
  .breadcrumb .sep { margin: 0 .35rem; color: #b0b4ba; }
  .breadcrumb .current { color: #1c2024; font-weight: 600; }
  .eyebrow { margin: 0 0 .25rem; font-size: .8rem; letter-spacing: .04em; text-transform: uppercase; color: #6b7280; }
  h1 { margin: 0 0 1rem; font-size: 1.35rem; }
  .azbar { display: flex; flex-wrap: wrap; gap: .25rem; margin: 0 0 1rem; }
  .azbar a { display: inline-flex; min-width: 1.6rem; justify-content: center; padding: .2rem .35rem; border-radius: 6px; background: #eef2ff; color: #2563eb; text-decoration: none; font-size: .85rem; font-weight: 600; }
  .azbar a:hover { background: #2563eb; color: #fff; }
  .pager { display: flex; align-items: center; gap: 1rem; margin: 1rem 0; font-size: .9rem; }
  .pager a { color: #2563eb; text-decoration: none; }
  .pager .disabled { color: #c0c4ca; }
  .pager .pos { color: #6b7280; }
  .code { font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; }
  ul.entries { list-style: none; margin: 0; padding: 0; border-top: 1px solid #ececf0; }
  ul.entries li { border-bottom: 1px solid #f1f2f4; }
  ul.entries a { display: flex; gap: .85rem; align-items: baseline; padding: .4rem .5rem; color: #1c2024; text-decoration: none; }
  ul.entries a:hover { background: #eef2ff; }
  ul.entries .code { color: #2563eb; font-size: .8rem; min-width: 6.5rem; }
  ul.entries .etitle { flex: 1; }
  ul.entries .etag { font-size: .72rem; text-transform: uppercase; letter-spacing: .03em; color: #9ca3af; }
</style>
</head>
<body>
<main class="card">
  <nav class="breadcrumb"><a href="{{ home_href }}">UNSPSC</a><span class="sep">›</span><span class="current">A–Z index</span></nav>
  <header>
    <p class="eyebrow">A–Z index · Page {{ page_num }} of {{ page_count }}</p>
    <h1>{{ guide_first }} <span style="color:#9ca3af">…</span> {{ guide_last }}</h1>
  </header>
  <nav class="azbar" aria-label="Jump to letter">
    {% for j in jumps %}<a href="{{ j.href }}">{{ j.label }}</a>{% endfor %}
  </nav>
  <nav class="pager">
    {% if prev_href %}<a href="{{ prev_href }}">‹ prev</a>{% else %}<span class="disabled">‹ prev</span>{% endif %}
    <span class="pos">Page {{ page_num }} of {{ page_count }}</span>
    {% if next_href %}<a href="{{ next_href }}">next ›</a>{% else %}<span class="disabled">next ›</span>{% endif %}
  </nav>
  <ul class="entries">
    {% for e in entries %}
    <li><a href="{{ e.href }}"><span class="code">{{ e.display }}</span><span class="etitle">{{ e.title }}</span><span class="etag">{{ e.name }}</span></a></li>
    {% endfor %}
  </ul>
  <nav class="pager">
    {% if prev_href %}<a href="{{ prev_href }}">‹ prev</a>{% else %}<span class="disabled">‹ prev</span>{% endif %}
    <span class="pos">Page {{ page_num }} of {{ page_count }}</span>
    {% if next_href %}<a href="{{ next_href }}">next ›</a>{% else %}<span class="disabled">next ›</span>{% endif %}
  </nav>
</main>
</body>
</html>
